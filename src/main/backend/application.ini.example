
[main]

DatabaseType = PostgreSQL
DatabaseHost = localhost
DatabasePort = 5432
DatabaseName = ownsona
DatabaseUser = ownsona
DatabasePassword = XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Used to set additional database connection parameters to the connection string
# DatabaseConnectionParameters =

# Max number of simultaneous REST services (any additional are put on a queue)
MaxWorkerThreads = 30

# If a user is inactive for this many seconds, they get auto-logged off
UserInactiveSeconds = 900

# Require authentication even when no SQL database is configured
# Set to true when using an alternative data store for user authentication
# RequireAuthentication = false

# ===== OWNSONA MCP SERVER SETTINGS =====
# Secrets and behavior knobs for the MCP server.  Required keys must be set
# before first request; the servlet fails to load otherwise.

# --- Required: the servlet fails to load if any of these are missing. ---

# Embedding provider name, recorded on each row.
EMBEDDING_PROVIDER = openai

# Embeddings endpoint URL.
EMBEDDING_ENDPOINT = https://api.openai.com/v1/embeddings

# API key for the embeddings endpoint (provider-agnostic; e.g. an OpenAI key for the OpenAI provider).
EMBEDDING_API_KEY = XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Embedding model name, recorded on each row.
EMBEDDING_MODEL = text-embedding-3-small

# Embedding vector dimensions.  Must match the vector(N) column type in sql/001_init.sql.
EMBEDDING_DIMENSIONS = 1536

# Login credentials for the OAuth authorization server's consent page.
# You invent these --- they are not tied to any external account (not
# OpenAI, not Anthropic, not Google, not your Unix login).  When an
# MCP client (Claude, ChatGPT, etc.) connects, it opens a browser tab
# to the AS login page which asks for these two values.  Enter them,
# click Allow, and the AS issues the client an access token.  The
# user does not see the login page again until the refresh token
# expires (30 days by default).
# Single-user server, so one pair is enough.  Plaintext is acceptable
# here because this file is chmod 600 and already holds the database
# password and the embeddings API key.
OWNSONA_LOGIN_USERNAME = <pick-any-username>
OWNSONA_LOGIN_PASSWORD = <pick-a-strong-password>

# --- Optional with sensible defaults. ---

# User-id stamped on every memory in single-user mode.
OWNSONA_USER_ID = default

# Default 'limit' for the recall tool when the client doesn't specify one.
DEFAULT_RECALL_LIMIT = 8

# Hard cap on 'limit' the client may request from any tool.
MAX_RECALL_LIMIT = 50

# Maximum chars in a single memory's text field.
MAX_TEXT_CHARS = 16000

# Maximum items per remember_batch call.
MAX_BATCH_SIZE = 200

# Switch to true alongside a new EMBEDDING_MODEL / EMBEDDING_PROVIDER /
# EMBEDDING_DIMENSIONS to re-embed every stored memory under the new
# model on next startup.  See REEMBED.md for the full procedure.
# After a clean run the server auto-flips this back to false so a
# subsequent restart doesn't re-trigger.
REEMBED_ON_STARTUP = false

# ===== OAUTH 2.1 SETTINGS =====
# OwnSona runs both an OAuth 2.1 resource server (validates tokens on
# every /mcp request) and an embedded authorization server (issues
# tokens at /oauth/authorize and /oauth/token, with dynamic client
# registration at /oauth/register and a JWKS at /oauth/jwks).  MCP
# clients discover everything by fetching
#   https://<your-host>/.well-known/oauth-protected-resource
# which points them at the AS metadata at
#   https://<your-host>/.well-known/oauth-authorization-server
# Both endpoints are auto-registered by the framework.
#
# Substitute your public hostname (the one your TLS cert covers and
# that you'll point MCP clients at) for <your-host> below.

# Issuer URL of the authorization server.  Required.  Everything else
# is derived from this:
#   * resource identifier ........ defaults to this URL (the 'aud' claim)
#   * AS issuer (in metadata) .... defaults to this URL
#   * JWKS URI ................... auto-discovered via the RFC 8414
#                                  metadata document the AS publishes
OAuthAuthorizationServer = https://<your-host>

# Master switch for the embedded authorization server.  When true the
# /oauth/* endpoints come alive; when false they all return 404 (the
# resource server can still validate tokens issued elsewhere).
OAuthAsEnabled = true

# --- Optional overrides (uncomment only when defaults don't fit). ---

# Comma- or space-separated list of scopes every token must carry.
# Empty / unset means "no scope requirement" --- any token validly
# signed by the AS for the right audience is accepted.
# OAuthRequiredScopes =

# Override the resource identifier (the value tokens must carry as
# 'aud').  Default = OAuthAuthorizationServer above.  Set this if you
# want tokens bound to a more specific URL (e.g. https://<your-host>/mcp).
# OAuthResourceIdentifier = https://<your-host>/mcp

# Override the AS issuer URL announced in the metadata document.
# Default = OAuthAuthorizationServer above.
# OAuthAsIssuer = https://<your-host>

# Override the JWKS URL the resource server fetches signing keys from.
# Default = auto-discovered from the AS's RFC 8414 metadata document at
# <issuer>/.well-known/oauth-authorization-server.  Set this only when
# you're pointing the RS at an AS that publishes neither RFC 8414 nor
# OIDC discovery (rare).
# OAuthJwksUri = https://<your-host>/oauth/jwks

# ===== DATABASE CONNECTION POOL SETTINGS =====
# These settings control the C3P0 connection pool behavior
# Uncomment and adjust for production/large applications

# Minimum number of connections to maintain in pool
# DatabaseMinPoolSize = 10

# Initial number of connections when pool starts
# DatabaseInitialPoolSize = 10

# Maximum number of connections allowed in pool
# For large applications: set to (CPU cores * 4) or higher based on load
# DatabaseMaxPoolSize = 100

# Number of connections to acquire when pool needs to grow
# DatabaseAcquireIncrement = 5

# Milliseconds to wait for a connection before timing out
# DatabaseCheckoutTimeout = 10000

# Maximum number of prepared statements to cache (improves performance)
# DatabaseMaxStatements = 500

# Maximum statements to cache per connection
# DatabaseMaxStatementsPerConnection = 25

# Seconds between testing idle connections (0 = disabled)
# DatabaseIdleTestPeriod = 300

# Seconds before removing idle connections (0 = never)
# DatabaseMaxIdleTime = 1800

# Test connections when checking out from pool (impacts performance)
# DatabaseTestOnCheckout = false

# Test connections when returning to pool (recommended)
# DatabaseTestOnCheckin = true

# Number of helper threads for pool management
# DatabaseHelperThreads = 10

# Seconds before forcibly reclaiming unreturned connections
# DatabaseUnreturnedTimeout = 60

# Enable stack traces for debugging unreturned connections (disable in production!)
# DatabaseDebugStackTraces = false
